{
  "name": "@nortix/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/apps/api/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/apps/api/src/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "simulate:event": "tsx src/jobs/simulate-event.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@nortix/database": "workspace:*",
    "@nortix/integrations": "workspace:*",
    "@nortix/plugin-sdk": "workspace:*",
    "@nortix/shared": "workspace:*",
    "@prisma/client": "^6.12.0",
    "fastify": "^5.4.0",
    "fastify-plugin": "^5.0.1",
    "firebase-admin": "^13.4.0",
    "pino": "^9.7.0",
    "prisma": "^6.12.0",
    "zod": "^4.0.10"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "tsx": "^4.20.3",
    "vitest": "^3.2.4"
  }
}
