generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLAYER
  SERVER_OWNER
  MODERATOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  LIMITED
  UNDER_REVIEW
  SUSPENDED
  BANNED
}

enum ServerEdition {
  JAVA
  BEDROCK
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

enum VerificationScope {
  SERVER
  PROXY_NETWORK
  PROXY_CHILD
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN
  FLAGGED
}

enum CampaignStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  CHANGES_REQUESTED
  APPROVED
  SCHEDULED
  ACTIVE
  PAUSED
  COMPLETED
  REJECTED
  ARCHIVED
}

enum ParticipationStatus {
  JOINED
  ACTIVE
  COMPLETED
  ABANDONED
  REJECTED
  UNDER_REVIEW
  DISQUALIFIED
}

enum CompletionStatus {
  PENDING
  VERIFIED
  REJECTED
  UNDER_REVIEW
}

enum LedgerDirection {
  CREDIT
  DEBIT
}

enum EarningsTransactionType {
  MILESTONE_REWARD
  MANUAL_ADJUSTMENT
  WITHDRAWAL_RESERVATION
  WITHDRAWAL_COMPLETION
  WITHDRAWAL_CANCELLATION
  REFUND_REVERSAL
  FRAUD_REVERSAL
  PROMOTIONAL_SUBSIDY
  MIGRATION_ADJUSTMENT
}

enum SparksTransactionType {
  CAMPAIGN_REWARD
  DAILY_QUEST
  STREAK
  ACHIEVEMENT
  SEASONAL_EVENT
  REFERRAL
  COMMUNITY_ACTIVITY
  COSMETIC_PURCHASE
  MANUAL_ADJUSTMENT
}

enum CampaignCreditTransactionType {
  PURCHASED
  PROMOTIONAL
  SPENT
  PROMOTIONAL_EXPIRED
  REFUND
  INTERNAL_ADJUSTMENT
}

enum WithdrawalStatus {
  REQUESTED
  UNDER_REVIEW
  APPROVED
  PROCESSING
  PAID
  REJECTED
  CANCELLED
  FAILED
}

enum AnalyticsSource {
  WEB
  MANUAL
  SERVER_PLUGIN
  CLIENT_MOD
  API
}

enum RiskState {
  CLEAR
  FLAGGED
  UNDER_REVIEW
  ESCALATED
  RESOLVED
}

enum ServerTeamRole {
  ADMIN
  MANAGER
  OPERATOR
  ANALYST
}

enum TeamInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  REVOKED
  EXPIRED
}

enum IdentityClaimStatus {
  PENDING
  COMPLETED
  EXPIRED
  CANCELLED
}

enum CrackedLinkStatus {
  PENDING
  ACTIVE
  EXPIRED
  RELEASED
  PLAYED_BEFORE
}

enum NotificationCategory {
  CAMPAIGN
  QUEST
  SPARKS
  SERVER
  TEAM
  SECURITY
  SYSTEM
}

enum AdminMessageAudience {
  ALL_USERS
  PLAYERS
  SERVER_OWNERS
  LIMITED_ACCOUNTS
  USER
}

enum AdminMessageSeverity {
  INFO
  SUCCESS
  WARNING
  CRITICAL
}

enum AdminMessageStatus {
  DRAFT
  SENT
}

model User {
  id                        String                      @id @default(cuid())
  firebaseUid               String                      @unique
  username                  String                      @unique
  displayName               String
  email                     String                      @unique
  avatarUrl                 String?
  roles                     UserRole[]                  @default([PLAYER])
  status                    UserStatus                  @default(ACTIVE)
  countryCode               String?
  preferredCurrency         String                      @default("USD")
  publicProfile             Json                        @default("{}")
  moderationState           Json                        @default("{}")
  reputationScore           Int                         @default(0)
  reputationTier            String                      @default("New Tester")
  testerLevel               Int                         @default(1)
  sparksBalanceCache        Int                         @default(0)
  earningsBalanceCache      Int                         @default(0)
  pendingEarningsCache      Int                         @default(0)
  createdAt                 DateTime                    @default(now())
  lastActiveAt              DateTime                    @default(now())
  minecraftIdentities       MinecraftIdentity[]
  ownedServers              Server[]                    @relation("ServerOwner")
  serverMemberships         ServerTeamMember[]          @relation("ServerTeamUser")
  invitedServerMembers      ServerTeamMember[]          @relation("ServerTeamInviter")
  sentServerInvites         ServerTeamInvite[]          @relation("ServerInviteSender")
  receivedServerInvites     ServerTeamInvite[]          @relation("ServerInviteRecipient")
  ownedCampaigns            Campaign[]                  @relation("CampaignOwner")
  participations            CampaignParticipation[]
  reviews                   Review[]
  withdrawals               WithdrawalRequest[]         @relation("WithdrawalPlayer")
  reviewedWithdrawals       WithdrawalRequest[]         @relation("WithdrawalReviewer")
  earningsLedger            EarningsLedgerEntry[]       @relation("EarningsUser")
  createdEarningsEntries    EarningsLedgerEntry[]       @relation("EarningsCreator")
  sparksLedger              SparksLedgerEntry[]         @relation("SparksUser")
  createdSparksEntries      SparksLedgerEntry[]         @relation("SparksCreator")
  campaignCreditLedger      CampaignCreditLedgerEntry[] @relation("CampaignCreditOwner")
  createdCreditEntries      CampaignCreditLedgerEntry[] @relation("CampaignCreditCreator")
  reviewedCompletions       MilestoneCompletion[]       @relation("CompletionReviewer")
  cosmeticPurchases         CosmeticPurchase[]
  analyticsEvents           AnalyticsEvent[]
  fraudFlags                FraudFlag[]                 @relation("FraudSubjectUser")
  createdFraudFlags         FraudFlag[]                 @relation("FraudFlagCreator")
  moderationCases           ModerationCase[]            @relation("ModerationSubjectUser")
  assignedCases             ModerationCase[]            @relation("ModerationAssignee")
  auditLogs                 AuditLog[]                  @relation("AuditActor")
  userQuests                UserQuest[]
  badgeAwards               BadgeAward[]
  premiumIdentityClaims     PremiumIdentityClaim[]
  crackedAccountLinks       CrackedAccountLink[]
  minecraftIdentityActivity MinecraftIdentityActivity[]
  notificationPreference    NotificationPreference?
  notifications             Notification[]
  createdAdminMessages      AdminMessage[]              @relation("AdminMessageCreator")
  targetedAdminMessages     AdminMessage[]              @relation("AdminMessageTarget")
  adminMessageDeliveries    AdminMessageDelivery[]

  @@index([status])
  @@index([reputationScore])
}

model NotificationPreference {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignActivity    Boolean  @default(true)
  questsAndStreaks    Boolean  @default(true)
  sparksActivity      Boolean  @default(true)
  serverOperations    Boolean  @default(true)
  teamActivity        Boolean  @default(true)
  productUpdates      Boolean  @default(true)
  emailProductUpdates Boolean  @default(false)
  updatedAt           DateTime @updatedAt
}

model Notification {
  id          String               @id @default(cuid())
  recipientId String
  recipient   User                 @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  category    NotificationCategory
  title       String
  body        String
  actionUrl   String?
  dedupeKey   String?
  readAt      DateTime?
  archivedAt  DateTime?
  createdAt   DateTime             @default(now())

  @@unique([recipientId, dedupeKey])
  @@index([recipientId, archivedAt, createdAt])
  @@index([recipientId, readAt, createdAt])
}

model AdminMessage {
  id           String                 @id @default(cuid())
  createdById  String
  createdBy    User                   @relation("AdminMessageCreator", fields: [createdById], references: [id])
  targetUserId String?
  targetUser   User?                  @relation("AdminMessageTarget", fields: [targetUserId], references: [id])
  audience     AdminMessageAudience
  severity     AdminMessageSeverity   @default(INFO)
  status       AdminMessageStatus     @default(DRAFT)
  title        String
  body         String
  actionUrl    String?
  sentAt       DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  deliveries   AdminMessageDelivery[]

  @@index([status, createdAt])
  @@index([createdById, createdAt])
}

model AdminMessageDelivery {
  id          String       @id @default(cuid())
  messageId   String
  message     AdminMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  recipientId String
  recipient   User         @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  readAt      DateTime?
  archivedAt  DateTime?
  deliveredAt DateTime     @default(now())

  @@unique([messageId, recipientId])
  @@index([recipientId, archivedAt, deliveredAt])
  @@index([recipientId, readAt, deliveredAt])
}

model MinecraftIdentity {
  id                 String                  @id @default(cuid())
  uuid               String                  @unique
  username           String
  lastKnownUsername  String
  verified           Boolean                 @default(false)
  verificationMethod String?
  userId             String
  user               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt          DateTime                @default(now())
  participations     CampaignParticipation[]

  @@index([userId])
}

model PremiumIdentityClaim {
  id          String              @id @default(cuid())
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash    String              @unique
  status      IdentityClaimStatus @default(PENDING)
  expiresAt   DateTime
  completedAt DateTime?
  createdAt   DateTime            @default(now())

  @@index([userId, status, createdAt])
  @@index([status, expiresAt])
}

model MinecraftIdentityActivity {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  serverId          String?
  server            Server?  @relation(fields: [serverId], references: [id], onDelete: SetNull)
  type              String
  identityKind      String
  minecraftUuid     String?
  minecraftUsername String?
  metadata          Json     @default("{}")
  createdAt         DateTime @default(now())

  @@index([userId, createdAt])
  @@index([serverId, createdAt])
}

model Server {
  id                        String                      @id @default(cuid())
  ownerId                   String
  owner                     User                        @relation("ServerOwner", fields: [ownerId], references: [id])
  name                      String
  slug                      String                      @unique
  description               String
  hostname                  String
  port                      Int                         @default(25565)
  versions                  String[]
  edition                   ServerEdition
  categories                String[]
  tags                      String[]
  logoUrl                   String?
  bannerUrl                 String?
  screenshotUrls            String[]
  discordUrl                String?
  websiteUrl                String?
  verificationStatus        VerificationStatus          @default(UNVERIFIED)
  verificationScope         VerificationScope           @default(SERVER)
  verificationParentId      String?
  verificationParent        Server?                     @relation("ProxyNetworkServers", fields: [verificationParentId], references: [id], onDelete: SetNull)
  networkServers            Server[]                    @relation("ProxyNetworkServers")
  moderationStatus          ModerationStatus            @default(PENDING)
  claimed                   Boolean                     @default(false)
  online                    Boolean                     @default(false)
  publicListing             Boolean                     @default(false)
  playerCount               Int?
  maxPlayers                Int?
  pluginCapabilities        Json                        @default("[]")
  pluginLastSeenAt          DateTime?
  pluginInstanceId          String?
  playerHistorySyncedAt     DateTime?
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime                    @updatedAt
  verifications             ServerVerification[]
  campaigns                 Campaign[]
  reviews                   Review[]
  analyticsEvents           AnalyticsEvent[]
  integrationKeys           IntegrationApiKey[]
  teamMembers               ServerTeamMember[]
  teamInvites               ServerTeamInvite[]
  crackedAccountLinks       CrackedAccountLink[]
  playerPresences           ServerPlayerPresence[]
  activitySamples           ServerActivitySample[]
  minecraftIdentityActivity MinecraftIdentityActivity[]

  @@index([ownerId])
  @@index([verificationParentId])
  @@index([publicListing, moderationStatus])
}

model ServerActivitySample {
  id            String   @id
  serverId      String
  server        Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  observedAt    DateTime
  receivedAt    DateTime @default(now())
  onlinePlayers Int
  maxPlayers    Int?
  platform      String
  pluginVersion String
  serverVersion String?
  backendCounts Json     @default("{}")
  playerHashes  String[]

  @@index([serverId, observedAt])
}

model ServerPlayerPresence {
  id                 String   @id @default(cuid())
  serverId           String
  server             Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  normalizedUsername String
  minecraftUsername  String
  firstSeenAt        DateTime @default(now())
  lastSeenAt         DateTime @default(now())

  @@unique([serverId, normalizedUsername])
  @@index([serverId, lastSeenAt])
}

model CrackedAccountLink {
  id                 String                  @id @default(cuid())
  userId             String
  user               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  serverId           String
  server             Server                  @relation(fields: [serverId], references: [id], onDelete: Cascade)
  minecraftUsername  String
  normalizedUsername String
  status             CrackedLinkStatus       @default(PENDING)
  reservedAt         DateTime                @default(now())
  expiresAt          DateTime
  activatedAt        DateTime?
  releasedAt         DateTime?
  releaseReason      String?
  participations     CampaignParticipation[]

  @@index([userId, reservedAt])
  @@index([serverId, normalizedUsername, status])
  @@index([status, expiresAt])
}

model ServerTeamMember {
  id          String         @id @default(cuid())
  serverId    String
  server      Server         @relation(fields: [serverId], references: [id], onDelete: Cascade)
  userId      String
  user        User           @relation("ServerTeamUser", fields: [userId], references: [id], onDelete: Cascade)
  role        ServerTeamRole
  invitedById String
  invitedBy   User           @relation("ServerTeamInviter", fields: [invitedById], references: [id])
  acceptedAt  DateTime       @default(now())
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([serverId, userId])
  @@index([userId])
}

model ServerTeamInvite {
  id          String           @id @default(cuid())
  serverId    String
  server      Server           @relation(fields: [serverId], references: [id], onDelete: Cascade)
  inviterId   String
  inviter     User             @relation("ServerInviteSender", fields: [inviterId], references: [id])
  inviteeId   String
  invitee     User             @relation("ServerInviteRecipient", fields: [inviteeId], references: [id], onDelete: Cascade)
  role        ServerTeamRole
  status      TeamInviteStatus @default(PENDING)
  expiresAt   DateTime
  respondedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([inviteeId, status, createdAt])
  @@index([serverId, status])
}

model ServerVerification {
  id         String             @id @default(cuid())
  serverId   String
  server     Server             @relation(fields: [serverId], references: [id], onDelete: Cascade)
  provider   String
  challenge  Json
  evidence   Json?
  status     VerificationStatus @default(PENDING)
  reviewedBy String?
  reviewNote String?
  expiresAt  DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([serverId, status])
}

model Campaign {
  id                    String                  @id @default(cuid())
  serverId              String
  server                Server                  @relation(fields: [serverId], references: [id])
  ownerId               String
  owner                 User                    @relation("CampaignOwner", fields: [ownerId], references: [id])
  title                 String
  description           String
  status                CampaignStatus          @default(DRAFT)
  category              String
  internalBudgetCents   Int
  campaignBudgetCredits Int                     @default(0)
  publicRewardCents     Int
  startsAt              DateTime
  endsAt                DateTime
  maxParticipants       Int
  completionLimit       Int
  minimumSparksReward   Int                     @default(0)
  maximumSparksReward   Int                     @default(0)
  potentialExposureMin  Int                     @default(0)
  potentialExposureMax  Int                     @default(0)
  automaticVerification Boolean                 @default(true)
  eligibilityRules      Json                    @default("{}")
  versionRequirements   String[]
  regionRestrictions    String[]
  moderationNotes       String?
  rejectionReason       String?
  internalRiskScore     Int                     @default(0)
  publishedAt           DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  milestones            CampaignMilestone[]
  participations        CampaignParticipation[]
  analyticsEvents       AnalyticsEvent[]
  fraudFlags            FraudFlag[]
  moderationCases       ModerationCase[]

  @@index([status, startsAt, endsAt])
  @@index([serverId])
  @@index([ownerId])
}

model MilestoneTemplate {
  id                      String   @id @default(cuid())
  type                    String   @unique
  title                   String
  description             String
  verificationMethods     String[]
  requiredConfiguration   Json
  expectedDurationMinutes Int
  minimumRewardCents      Int
  maximumRewardCents      Int
  abuseRisk               Int
  manualReviewRequired    Boolean  @default(false)
  enabled                 Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model CampaignMilestone {
  id                     String                @id @default(cuid())
  campaignId             String
  campaign               Campaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  templateType           String
  title                  String
  publicInstructions     String
  verificationConfig     Json
  order                  Int
  publicRewardCents      Int
  sparksReward           Int
  completionRequirements Json
  verificationMethod     String
  reviewRequired         Boolean               @default(false)
  maximumCompletionCount Int?
  completions            MilestoneCompletion[]

  @@unique([campaignId, order])
  @@index([campaignId])
}

model CampaignParticipation {
  id                     String                @id @default(cuid())
  playerId               String
  player                 User                  @relation(fields: [playerId], references: [id])
  campaignId             String
  campaign               Campaign              @relation(fields: [campaignId], references: [id])
  minecraftIdentityId    String?
  minecraftIdentity      MinecraftIdentity?    @relation(fields: [minecraftIdentityId], references: [id])
  crackedAccountLinkId   String?
  crackedAccountLink     CrackedAccountLink?   @relation(fields: [crackedAccountLinkId], references: [id])
  status                 ParticipationStatus   @default(JOINED)
  currentMilestone       Int                   @default(0)
  eligibilitySnapshot    Json
  disqualificationReason String?
  fraudReviewState       RiskState             @default(CLEAR)
  joinedAt               DateTime              @default(now())
  lastActivityAt         DateTime              @default(now())
  completedAt            DateTime?
  completions            MilestoneCompletion[]
  feedback               FeedbackResponse?
  analyticsEvents        AnalyticsEvent[]

  @@unique([playerId, campaignId])
  @@index([campaignId, status])
  @@index([playerId, status])
  @@index([crackedAccountLinkId])
}

model MilestoneCompletion {
  id                  String                @id @default(cuid())
  participationId     String
  participation       CampaignParticipation @relation(fields: [participationId], references: [id], onDelete: Cascade)
  milestoneId         String
  milestone           CampaignMilestone     @relation(fields: [milestoneId], references: [id])
  submittedAt         DateTime              @default(now())
  evidence            Json
  verificationSource  String
  status              CompletionStatus      @default(PENDING)
  reviewedById        String?
  reviewedBy          User?                 @relation("CompletionReviewer", fields: [reviewedById], references: [id])
  reviewedAt          DateTime?
  rejectionReason     String?
  rewardTransactionId String?               @unique
  sparksTransactionId String?               @unique
  rewardTransaction   EarningsLedgerEntry?  @relation("CompletionEarnings", fields: [rewardTransactionId], references: [id])
  sparksTransaction   SparksLedgerEntry?    @relation("CompletionSparks", fields: [sparksTransactionId], references: [id])

  @@unique([participationId, milestoneId])
  @@index([status, submittedAt])
}

model FeedbackResponse {
  id                 String                @id @default(cuid())
  participationId    String                @unique
  participation      CampaignParticipation @relation(fields: [participationId], references: [id], onDelete: Cascade)
  overallRating      Int
  onboardingClarity  Int
  gameplayClarity    Int
  performance        Int
  difficulty         Int
  likelihoodToReturn Int
  comments           String
  bugReports         Json                  @default("[]")
  createdAt          DateTime              @default(now())
}

model Review {
  id               String           @id @default(cuid())
  serverId         String
  server           Server           @relation(fields: [serverId], references: [id])
  playerId         String
  player           User             @relation(fields: [playerId], references: [id])
  rating           Int
  text             String
  campaignLinked   Boolean          @default(false)
  moderationStatus ModerationStatus @default(PENDING)
  helpfulCount     Int              @default(0)
  createdAt        DateTime         @default(now())

  @@unique([serverId, playerId])
}

model WithdrawalRequest {
  id                           String           @id @default(cuid())
  playerId                     String
  player                       User             @relation("WithdrawalPlayer", fields: [playerId], references: [id])
  requestedAmountCents         Int
  currency                     String
  payoutProvider               String
  payoutDestinationReference   String
  status                       WithdrawalStatus @default(REQUESTED)
  feesCents                    Int              @default(0)
  finalPaidAmountCents         Int?
  reviewState                  RiskState        @default(CLEAR)
  fraudState                   RiskState        @default(CLEAR)
  providerTransactionReference String?
  reviewedById                 String?
  reviewedBy                   User?            @relation("WithdrawalReviewer", fields: [reviewedById], references: [id])
  internalNote                 String?
  createdAt                    DateTime         @default(now())
  updatedAt                    DateTime         @updatedAt
  completedAt                  DateTime?

  @@index([status, createdAt])
  @@index([playerId])
}

model EarningsLedgerEntry {
  id              String                  @id @default(cuid())
  userId          String
  user            User                    @relation("EarningsUser", fields: [userId], references: [id])
  direction       LedgerDirection
  amountCents     Int
  currency        String
  transactionType EarningsTransactionType
  referenceType   String
  referenceId     String
  idempotencyKey  String                  @unique
  createdById     String?
  createdBy       User?                   @relation("EarningsCreator", fields: [createdById], references: [id])
  internalNote    String?
  createdAt       DateTime                @default(now())
  completion      MilestoneCompletion?    @relation("CompletionEarnings")

  @@index([userId, currency, createdAt])
  @@index([referenceType, referenceId])
}

model SparksLedgerEntry {
  id              String                @id @default(cuid())
  userId          String
  user            User                  @relation("SparksUser", fields: [userId], references: [id])
  direction       LedgerDirection
  amount          Int
  transactionType SparksTransactionType
  referenceType   String
  referenceId     String
  idempotencyKey  String                @unique
  createdById     String?
  createdBy       User?                 @relation("SparksCreator", fields: [createdById], references: [id])
  internalNote    String?
  createdAt       DateTime              @default(now())
  completion      MilestoneCompletion?  @relation("CompletionSparks")

  @@index([userId, createdAt])
}

model CampaignCreditLedgerEntry {
  id               String                        @id @default(cuid())
  ownerId          String
  owner            User                          @relation("CampaignCreditOwner", fields: [ownerId], references: [id])
  direction        LedgerDirection
  amountCents      Int
  purchasedCents   Int                           @default(0)
  promotionalCents Int                           @default(0)
  transactionType  CampaignCreditTransactionType
  referenceType    String
  referenceId      String
  idempotencyKey   String                        @unique
  expiresAt        DateTime?
  createdById      String?
  createdBy        User?                         @relation("CampaignCreditCreator", fields: [createdById], references: [id])
  internalNote     String?
  createdAt        DateTime                      @default(now())

  @@index([ownerId, createdAt])
  @@index([expiresAt])
}

model CosmeticItem {
  id          String             @id @default(cuid())
  slug        String             @unique
  name        String
  description String
  type        String
  sparksPrice Int
  rarity      String
  season      String?
  preview     Json
  available   Boolean            @default(true)
  purchases   CosmeticPurchase[]
  createdAt   DateTime           @default(now())
}

model CosmeticPurchase {
  id                  String       @id @default(cuid())
  userId              String
  user                User         @relation(fields: [userId], references: [id])
  itemId              String
  item                CosmeticItem @relation(fields: [itemId], references: [id])
  sparksLedgerEntryId String       @unique
  createdAt           DateTime     @default(now())

  @@unique([userId, itemId])
}

model AnalyticsEvent {
  id              String                 @id
  userId          String?
  user            User?                  @relation(fields: [userId], references: [id])
  serverId        String?
  server          Server?                @relation(fields: [serverId], references: [id])
  campaignId      String?
  campaign        Campaign?              @relation(fields: [campaignId], references: [id])
  participationId String?
  participation   CampaignParticipation? @relation(fields: [participationId], references: [id])
  source          AnalyticsSource
  type            String
  occurredAt      DateTime
  metadata        Json
  createdAt       DateTime               @default(now())

  @@index([campaignId, type, occurredAt])
  @@index([serverId, occurredAt])
}

model IntegrationApiKey {
  id         String    @id @default(cuid())
  serverId   String
  server     Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  name       String
  keyHash    String
  scopes     String[]
  lastFour   String
  expiresAt  DateTime?
  revokedAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([serverId])
  @@index([keyHash])
}

model PaymentEvent {
  id              String    @id @default(cuid())
  providerEventId String    @unique
  type            String
  referenceId     String
  amountCents     Int
  currency        String
  payload         Json
  status          String
  idempotencyKey  String    @unique
  processedAt     DateTime?
  error           String?
  createdAt       DateTime  @default(now())
}

model FraudFlag {
  id              String    @id @default(cuid())
  userId          String?
  user            User?     @relation("FraudSubjectUser", fields: [userId], references: [id])
  campaignId      String?
  campaign        Campaign? @relation(fields: [campaignId], references: [id])
  type            String
  severity        Int
  state           RiskState @default(FLAGGED)
  privacySafeData Json
  createdById     String?
  createdBy       User?     @relation("FraudFlagCreator", fields: [createdById], references: [id])
  createdAt       DateTime  @default(now())
  resolvedAt      DateTime?

  @@index([state, severity])
}

model ModerationCase {
  id            String    @id @default(cuid())
  type          String
  status        String
  priority      String
  subjectUserId String?
  subjectUser   User?     @relation("ModerationSubjectUser", fields: [subjectUserId], references: [id])
  campaignId    String?
  campaign      Campaign? @relation(fields: [campaignId], references: [id])
  assignedToId  String?
  assignedTo    User?     @relation("ModerationAssignee", fields: [assignedToId], references: [id])
  summary       String
  evidence      Json
  resolution    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, priority])
}

model AuditLog {
  id             String   @id @default(cuid())
  actorId        String?
  actor          User?    @relation("AuditActor", fields: [actorId], references: [id])
  action         String
  entityType     String
  entityId       String
  beforeSnapshot Json?
  afterSnapshot  Json?
  reason         String?
  requestId      String?
  createdAt      DateTime @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([actorId, createdAt])
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  description String
  enabled     Boolean  @default(false)
  rules       Json     @default("{}")
  updatedAt   DateTime @updatedAt
}

model DailyQuest {
  id           String      @id @default(cuid())
  slug         String      @unique
  title        String
  description  String
  type         String
  target       Int
  sparksReward Int
  active       Boolean     @default(true)
  userQuests   UserQuest[]
}

model UserQuest {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  questId     String
  quest       DailyQuest @relation(fields: [questId], references: [id])
  progress    Int        @default(0)
  completedAt DateTime?
  questDate   DateTime

  @@unique([userId, questId, questDate])
}

model Badge {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  description String
  icon        String
  rarity      String
  awards      BadgeAward[]
}

model BadgeAward {
  id        String   @id @default(cuid())
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  awardedAt DateTime @default(now())

  @@unique([badgeId, userId])
}
